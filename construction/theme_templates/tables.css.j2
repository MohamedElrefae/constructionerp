/* ===== TABLES: {{ theme_name }} ===== */
html[data-modern-theme="{{ theme_name }}"] .datatable {
    background: {{ surface_bg }} !important;
}

html[data-modern-theme="{{ theme_name }}"] .datatable .dt-header {
    background: {{ navbar_bg }} !important;
    border-bottom: 1px solid {{ border_color }} !important;
}

html[data-modern-theme="{{ theme_name }}"] .datatable .dt-row {
    border-bottom: 1px solid {{ border_color }}33 !important;
}

html[data-modern-theme="{{ theme_name }}"] .datatable .dt-row:hover {
    background: {{ accent_primary }}0d !important;
}

html[data-modern-theme="{{ theme_name }}"] .datatable .dt-cell {
    color: {{ text_primary }} !important;
}

html[data-modern-theme="{{ theme_name }}"] .datatable .dt-cell--header {
    color: {{ text_primary }} !important;
    font-weight: 600 !important;
}

html[data-modern-theme="{{ theme_name }}"] .list-row-head {
    background: {{ navbar_bg }} !important;
    border-bottom: 1px solid {{ border_color }} !important;
}

html[data-modern-theme="{{ theme_name }}"] .list-row {
    border-bottom: 1px solid {{ border_color }}33 !important;
}

html[data-modern-theme="{{ theme_name }}"] .list-row:hover {
    background: {{ accent_primary }}0d !important;
}

html[data-modern-theme="{{ theme_name }}"] .list-row .level-item {
    color: {{ text_primary }} !important;
}

html[data-modern-theme="{{ theme_name }}"] .list-row-head .list-subject {
    color: {{ text_primary }} !important;
    font-weight: 600 !important;
}

html[data-modern-theme="{{ theme_name }}"] .result {
    background: {{ surface_bg }} !important;
}
