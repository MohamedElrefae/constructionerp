/* ===== FORMS: {{ theme_name }} ===== */
html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .form-control {
    background: {{ surface_bg }};
    border-color: {{ border_color }};
    color: {{ text_primary }};
    border-radius: 8px;
    transition: all .2s ease;
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .form-control:focus {
    border-color: {{ accent_primary }};
{% if is_dark_mode %}
    box-shadow: 0 0 0 3px {{ accent_primary }}26;
{% else %}
    box-shadow: 0 0 0 3px {{ accent_primary }}1f;
{% endif %}
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .form-group label {
    color: {{ text_primary }};
    font-weight: 500;
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .form-section .section-head {
    color: {{ accent_primary }};
    border-bottom: 1px solid {{ border_color }};
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .dropdown-menu {
    background: {{ surface_bg }};
    border-color: {{ border_color }};
{% if is_dark_mode %}
    box-shadow: 0 4px 12px rgba(0,0,0,.3);
{% else %}
    box-shadow: 0 4px 12px rgba(0,0,0,.1);
{% endif %}
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .dropdown-item {
    color: {{ text_primary }};
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .dropdown-item:hover {
    background: {{ accent_primary }}19;
    color: {{ accent_primary }};
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] a {
    color: {{ accent_primary }};
    transition: color .2s ease;
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] a:hover {
    color: {{ accent_primary_hover }};
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] h1,
html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] h2,
html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] h3 {
    color: {{ text_primary }};
}

html[data-theme="{{ 'dark' if is_dark_mode else 'light' }}"] .control-label {
    color: {{ text_secondary }};
}
